# Reproducible, strict installation. See docs/engineering/supported-toolchain.md.

# Dependency versions are pinned exactly. `pnpm add` writes "1.2.3", never "^1.2.3".
save-exact=true

# An unmet or conflicting peer dependency fails the install instead of warning.
# Peer combinations are verified before a dependency is added; they are never
# forced through with --force, --legacy-peer-deps, or a relaxed setting.
strict-peer-dependencies=true

# Missing peers are not silently installed on our behalf. Every package in the
# tree is either declared here or brought in deliberately by a dependency.
auto-install-peers=false

# The engines.node constraint in package.json is enforced, not advisory.
engine-strict=true

# The lockfile is authoritative. CI additionally installs with --frozen-lockfile.
prefer-frozen-lockfile=true
