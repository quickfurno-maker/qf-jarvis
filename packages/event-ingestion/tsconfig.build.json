{
  "$schema": "https://json.schemastore.org/tsconfig",
  "extends": "../../tsconfig.base.json",
  "compilerOptions": {
    "rootDir": "./src",
    "outDir": "./dist",
    // Emit the incremental build info to the conventional name so `scripts/clean.mjs`
    // (which removes `tsconfig.tsbuildinfo`) clears it — otherwise a stale
    // `tsconfig.build.tsbuildinfo` would make `tsc --build` skip re-emitting `dist/`.
    "tsBuildInfoFile": "./tsconfig.tsbuildinfo"
  },

  // The EMITTING build, referenced by the root solution. Tests — and the
  // deterministic test-only key material under src/tests — are EXCLUDED, so nothing
  // from src/tests reaches dist/. The shipped package (the `exports` map points only
  // at ./dist) therefore contains no private key of any kind. Tests are type-checked,
  // without emit, by tsconfig.json.
  //
  // Project references make `tsc --build` compile these packages before this one and resolve
  // their declarations from source: @qf-jarvis/contracts for validated event preparation, and
  // @qf-jarvis/event-backbone for the atomic event-store write primitive (Stage 3.3 slice 3).
  "references": [{ "path": "../contracts" }, { "path": "../event-backbone" }],
  "include": ["src/**/*.ts"],
  "exclude": ["src/tests/**"]
}
