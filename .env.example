# QF Jarvis — example environment configuration.
# Copy to `.env` for local development and adjust as needed.
# NEVER commit a real `.env`; only this example file is tracked.

# Runtime mode: development | test | production
NODE_ENV=development

# Log verbosity: fatal | error | warn | info | debug | trace | silent
LOG_LEVEL=info

# Jarvis API bind address.
# Use 127.0.0.1 for local-only; set to 0.0.0.0 to accept external connections.
JARVIS_API_HOST=127.0.0.1
JARVIS_API_PORT=3000
